<Window x:Class="POE_Part3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POE_Part3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <!-- Outer Pink Border -->
    <Border Margin="0,16,16,16"
            Width="792"
            Height="352"
            CornerRadius="10"
            VerticalAlignment="Center"
            HorizontalAlignment="Right"
            Background="#FFFF3BA0">

        <!-- Main Chat Container -->
        <Grid Width="447"
              Height="324"
              Background="#FFDEDBDB">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="Chat"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="#FFFF3BA0"
                       Margin="10"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"/>

            <!-- Chat Area -->
            <Border Grid.Row="1"
                    Margin="10,0,10,50"
                    Background="White"
                    CornerRadius="12">

                <ScrollViewer x:Name="chatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel x:Name="chatPanel"
                                Margin="10"/>
                </ScrollViewer>
            </Border>

            <!-- Input TextBox -->
            <Border Grid.Row="1"
                    Width="320"
                    Height="32"
                    CornerRadius="16"
                    Background="White"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,10">

                <TextBox x:Name="User_input"
                         Text="Type your message"
                         Foreground="#FF575757"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="10,5"
                         VerticalContentAlignment="Center"/>
            </Border>

            <!-- Send Button -->
            <Border Grid.Row="1"
                    Width="88"
                    Height="32"
                    CornerRadius="16"
                    Background="#FFFF3BA0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,10,10">

                <Button x:Name="Button1"
                        Content="Send"
                        Click="btnSend_Click"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="White"
                        FontWeight="Bold"
                        Cursor="Hand"/>
            </Border>
            <Button Content="Button" HorizontalAlignment="Left" Margin="349,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.517,-0.35" Click="Button_Click" Height="26" Width="64"/>

        </Grid>
    </Border>
</Window>

